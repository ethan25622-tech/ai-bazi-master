{
  "schema_version": "mingli-case-library.v1",
  "case_policy": {
    "purpose": "Store structured life cases for training and regression checks of interpretation quality.",
    "privacy_rule": "Use anonymized or consented cases only. Do not store names, phone numbers, ID numbers, exact addresses, or raw private chat logs.",
    "quality_rule": "Each formal case must include birth data, source status, themes, observed events, judgement notes, and review status.",
    "supported_birth_range": "1902-03-01 onward for zydx-compatible pillar validation",
    "validation_priority_rules": {
      "P0": "Core precise validation. Birth year/month/day/hour/minute is explicit, location and timezone are clear, and the birth-time source is AA or birth-record grade.",
      "P1": "Usable precise validation with caution. Birth time is relatively credible, source level is A/B, or there is a documented but manageable dispute.",
      "P2": "Auxiliary reference only. Birth time comes from C-grade, traditional, rectified, biography-derived, or otherwise weak material. Do not use as a high-weight automated benchmark.",
      "P3": "Event sample only. Birth date is known but hour/minute is missing or unreliable. Do not validate hour pillar or exact chart.",
      "exclude": "Do not admit into the library when birth date, key event, or source cannot be traced."
    },
    "machine_use_policy": {
      "P0": "May enter automatic regression tests by default.",
      "P1": "May enter manual-review or low-weight regression sets.",
      "P2": "Use for interpretation-quality reference only; exclude from precise pillar validation.",
      "P3": "Use only for event-domain labels and narrative examples; exclude from precise chart validation."
    }
  },
